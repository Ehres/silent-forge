{
  "name": "silent-forge",
  "version": "1.0.0",
  "description": "Un outil invisible pour analyser et tirer parti des opportunités dans les jeux",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "calibrate": "ts-node src/calibrate.ts",
    "calibrate-cards": "ts-node src/calibrate-cards.ts",
    "test-clicks": "ts-node src/test-natural-clicks.ts",
    "example": "ts-node src/example.ts",
    "test-modules": "ts-node src/test.ts",
    "test-player": "ts-node src/main.ts test",
    "calibration": "ts-node src/main.ts calibration",
    "run-players": "ts-node src/main.ts players",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "automation",
    "ocr",
    "gaming",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jimp": "^0.2.28",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.0.0",
    "jimp": "^1.6.0",
    "tesseract.js": "^5.0.0"
  }
}
