{
  "name": "silent-forge",
  "version": "1.0.0",
  "description": "Un outil invisible pour analyser et tirer parti des opportunités dans les jeux",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "bun src/main.ts",
    "calibrate": "bun src/calibrate.ts",
    "calibrate-cards": "bun src/calibrate-cards.ts",
    "calibrate-ocr": "bun src/calibrate-ocr.ts",
    "test-implementation": "bun src/scripts/test-implementation.ts",
    "test-monument-ocr": "bun src/scripts/test-monument-ocr.ts",
    "test-sequential-rewards": "bun src/scripts/test-sequential-rewards.ts",
    "test-player": "bun src/main.ts test",
    "calibration": "bun src/main.ts calibration",
    "run-players": "bun src/main.ts players",
    "watch": "tsc --watch",
    "test": "bun test",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "automation",
    "ocr",
    "gaming",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.0.0",
    "jimp": "^1.6.0",
    "tesseract.js": "^5.0.0"
  }
}
